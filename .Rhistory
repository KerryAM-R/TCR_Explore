server <- function(input, output, session) {
observeEvent(input$overview_panels, {
if (input$overview_panels == "treemap_tab") {
# Open Treemap panel
shinyjs::runjs("$('#collapse_Treemap_panel .panel-collapse').eq(0).collapse('show');")
# Close Chord and Pie
shinyjs::runjs("
$('#collapse_Treemap_panel .panel-collapse').eq(1).collapse('hide');
$('#collapse_Treemap_panel .panel-collapse').eq(2).collapse('hide');
")
} else if (input$overview_panels == "chord_params") {
# Open Chord panel
shinyjs::runjs("$('#collapse_Treemap_panel .panel-collapse').eq(1).collapse('show');")
# Close Treemap and Pie
shinyjs::runjs("
$('#collapse_Treemap_panel .panel-collapse').eq(0).collapse('hide');
$('#collapse_Treemap_panel .panel-collapse').eq(2).collapse('hide');
")
} else if (input$overview_panels == "pie_params") {
# Open Pie panel
shinyjs::runjs("$('#collapse_Treemap_panel .panel-collapse').eq(2).collapse('show');")
# Close Treemap and Chord
shinyjs::runjs("
$('#collapse_Treemap_panel .panel-collapse').eq(0).collapse('hide');
$('#collapse_Treemap_panel .panel-collapse').eq(1).collapse('hide');
")
} else {
# Close all panels for any other tab
shinyjs::runjs("
$('#collapse_Treemap_panel .panel-collapse').collapse('hide');
")
}
}, ignoreInit = TRUE)
}
shinyApp(ui, server)
