server <- function(input, output, session) {
# Helper function to open one panel by index, close others
togglePanel <- function(panelIndex = NULL) {
# Get total number of panels
numPanels <- 3
for (i in 0:(numPanels-1)) {
if (!is.null(panelIndex) && i == panelIndex) {
shinyjs::runjs(sprintf("$('#collapse_Treemap_panel .panel-collapse').eq(%d).collapse('show');", i))
} else {
shinyjs::runjs(sprintf("$('#collapse_Treemap_panel .panel-collapse').eq(%d).collapse('hide');", i))
}
}
}
# Map tab values to panel index
tabToPanel <- list(
treemap_tab = 0,
chord_params = 1,
pie_params = 2
)
# Observe tab changes
observeEvent(input$overview_panels, {
panelIndex <- tabToPanel[[input$overview_panels]]
togglePanel(panelIndex)
}, ignoreInit = TRUE)
}
