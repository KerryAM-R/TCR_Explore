observeEvent(input$analysis_panel, {
if (input$analysis_panel == "treemap_tab") {
updateCollapse(session, "collapse_Treemap_panel", open = "treeParam")
} else {
updateCollapse(session, "collapse_Treemap_panel", open = NULL)
}
})
}
